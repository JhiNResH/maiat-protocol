# ─────────────────────────────────────────────
# Database (Supabase PostgreSQL)
# Get from: https://supabase.com → Project Settings → Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...

# ─────────────────────────────────────────────
# Auth (Privy)
# Get from: https://dashboard.privy.io → App Settings
# ─────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─────────────────────────────────────────────
# AI (Gemini)
# Get from: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ─────────────────────────────────────────────
# Blockchain — Wallet Keys
# Admin wallet (EAS attestations + on-chain writes)
# Relayer wallet (x402 payment relay)
# NEVER commit real keys — keep in .env.local only
# ─────────────────────────────────────────────
MAIAT_ADMIN_PRIVATE_KEY=0x...
BASE_RELAYER_PRIVATE_KEY=0x...
PRIVATE_KEY=0x...

# ─────────────────────────────────────────────
# On-chain Contract Addresses
# Deploy contracts first: cd contracts && forge script Deploy
# ─────────────────────────────────────────────
NEXT_PUBLIC_REVIEW_REGISTRY_ADDRESS=0x...
REVIEW_REGISTRY_ADDRESS=0x...
MAIAT_PAYMENT_ADDRESS=0x...

# ─────────────────────────────────────────────
# RPC — Alchemy
# Get from: https://dashboard.alchemy.com → Create App → Base Mainnet
# Falls back to public RPC if not set (slower, rate-limited)
# ─────────────────────────────────────────────
ALCHEMY_BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ALCHEMY_ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ALCHEMY_API_KEY=

# ─────────────────────────────────────────────
# Block Explorer API Keys (for on-chain scoring)
# ─────────────────────────────────────────────
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=

# ─────────────────────────────────────────────
# Internal API Security
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────
MAIAT_INTERNAL_TOKEN=
CRON_SECRET=

# ─────────────────────────────────────────────
# Rate Limiting (Upstash Redis) — optional
# Get from: https://console.upstash.com
# Rate limiting is disabled if not set
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────
# Hedera (attestation layer) — optional
# Get from: https://portal.hedera.com
# ─────────────────────────────────────────────
HEDERA_ACCOUNT_ID=
HEDERA_PRIVATE_KEY=
HEDERA_TOPIC_ID=

# ─────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
BASE_BUILDER_CODE=
