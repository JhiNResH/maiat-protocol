generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String   @id @default(cuid())
  address         String   @unique
  displayName     String?
  avatarUrl       String?
  reputationScore Int      @default(0)
  totalReviews    Int      @default(0)
  totalUpvotes    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reviews         Review[]
  votes           Vote[]

  @@index([address])
  @@index([reputationScore])
}

model Project {
  id              String    @id @default(cuid())
  address         String    @unique
  name            String
  slug            String    @unique @default(cuid())
  description     String?
  image           String?
  bannerImage     String?
  website         String?
  category        String    @default("m/ai-agents")
  avgRating       Float     @default(0)
  reviewCount     Int       @default(0)
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  athDropPct      Float?
  athPrice        Float?
  chain           String?
  coreFunctions   String?
  docs            String?
  github          String?
  humanScore      Int?
  marketCap       Float?
  marketUpdatedAt DateTime?
  offChainScore   Int?
  onChainScore    Int?
  price           Float?
  symbol          String?
  tier            String?
  trustGrade      String?
  trustScore      Int?
  trustUpdatedAt  DateTime?
  twitter         String?
  volume24h       Float?
  reviews         Review[]

  @@index([slug])
  @@index([address])
  @@index([category])
  @@index([chain])
  @@index([status])
  @@index([trustScore])
}

model Review {
  id              String   @id @default(cuid())
  rating          Int
  content         String
  upvotes         Int      @default(0)
  downvotes       Int      @default(0)
  status          String   @default("active")
  txHash          String?
  contentHash     String?
  onChainReviewId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reviewerId      String
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  reviewer        User     @relation(fields: [reviewerId], references: [id])
  votes           Vote[]

  @@index([reviewerId])
  @@index([projectId])
  @@index([createdAt])
  @@index([txHash])
}

model Vote {
  id        String   @id @default(cuid())
  direction String
  createdAt DateTime @default(now())
  voterId   String
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id])
  voter     User     @relation(fields: [voterId], references: [id])

  @@unique([voterId, reviewId])
  @@index([reviewId])
  @@index([voterId])
}

model ScarabBalance {
  id             String              @id @default(cuid())
  address        String              @unique
  balance        Int                 @default(0)
  totalEarned    Int                 @default(0)
  totalSpent     Int                 @default(0)
  totalPurchased Int                 @default(0)
  lastClaimAt    DateTime?
  streak         Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  transactions   ScarabTransaction[]

  @@index([address])
  @@index([balance])
}

model ScarabTransaction {
  id            String        @id @default(cuid())
  address       String
  amount        Int
  type          String
  description   String?
  referenceId   String?
  balanceAfter  Int
  createdAt     DateTime      @default(now())
  scarabBalance ScarabBalance @relation(fields: [address], references: [address])

  @@index([address])
  @@index([type])
  @@index([createdAt])
}

model ScarabPurchase {
  id           String    @id @default(cuid())
  address      String
  tier         String
  usdcAmount   Float
  scarabAmount Int
  txHash       String?
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  confirmedAt  DateTime?

  @@index([address])
  @@index([status])
}

model TrustReview {
  id           String   @id @default(cuid())
  address      String
  rating       Int
  comment      String   @default("")
  tags         String[] @default([])
  reviewer     String
  easReceiptId String?  // Optional Reference to the EASReceipt used for 5x weight
  weight       Int      @default(1) // 1x for raw, 5x for receipt-verified
  createdAt    DateTime @default(now())

  @@index([address])
  @@index([reviewer])
  @@index([createdAt])
}

model EASReceipt {
  id              String   @id @default(cuid())
  recipient       String   // The wallet address of the user who receives the receipt
  attester        String   // The service provider or Maiat Admin
  serviceProtocol String?  // e.g "Uniswap", "Virtuals Protocol"
  txHash          String?  // Reference to the on-chain transaction
  receiptJson     String   @db.Text // The actual signed EAS off-chain JSON
  isOffchain      Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([recipient])
  @@index([attester])
  @@index([createdAt])
}

// ============================================================================
// OPINION MARKETS - Stake Scarab on agent rankings
// ============================================================================

model Market {
  id          String           @id @default(cuid())
  title       String
  description String
  category    String           // "ai-agents" | "defi" | "mixed"
  status      String           @default("open") // "open" | "closed" | "resolved"
  opensAt     DateTime
  closesAt    DateTime         // opensAt + 14 days
  resolvedAt  DateTime?
  totalPool   Int              @default(0) // total Scarab in market
  winnerIds   String[]         @default([]) // project IDs that "won"
  createdAt   DateTime         @default(now())
  positions   MarketPosition[]

  @@index([status])
  @@index([category])
  @@index([closesAt])
}

model MarketPosition {
  id        String   @id @default(cuid())
  marketId  String
  projectId String   // agent being bet on
  voterId   String   // wallet address
  amount    Int      // Scarab staked (min 50)
  payout    Int?     // set at resolution
  createdAt DateTime @default(now())
  market    Market   @relation(fields: [marketId], references: [id])

  @@index([marketId])
  @@index([projectId])
  @@index([voterId])
}

// ── Agent Trust Check Log ─────────────────────────────────────────────────────
// Records every x402 trust-check API call. Powers `x402_checks` counter.
model AgentCheckLog {
  id             String   @id @default(cuid())
  checkedAddress String   // agent/protocol being checked
  checkerAddress String?  // who's checking (from x402 payment proof)
  paymentTxHash  String?  // USDC tx hash proving payment
  score          Int      // trust score at time of check
  verdict        String   // "proceed" | "caution" | "block"
  createdAt      DateTime @default(now())

  @@index([checkedAddress])
  @@index([checkerAddress])
}

// ── Outcome Report ────────────────────────────────────────────────────────────
// Buyer agents report job outcomes → feeds outcome_score in trust-check.
model OutcomeReport {
  id            String   @id @default(cuid())
  sellerAddress String   // agent/protocol that delivered
  buyerAddress  String   // who's reporting (verified via paymentTxHash)
  jobId         String?  // ACP job ID or x402 tx reference
  result        String   // "success" | "failed" | "dispute"
  paymentTxHash String?  // on-chain proof buyer paid seller (prevents fake reports)
  notes         String?
  createdAt     DateTime @default(now())

  @@index([sellerAddress])
  @@index([buyerAddress])
  @@index([result])
}
