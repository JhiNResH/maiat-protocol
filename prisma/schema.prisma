generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String   @id @default(cuid())
  address         String   @unique
  displayName     String?
  avatarUrl       String?
  reputationScore Int      @default(0)
  totalReviews    Int      @default(0)
  totalUpvotes    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reviews         Review[]
  votes           Vote[]

  @@index([address])
  @@index([reputationScore])
}

model Project {
  id              String    @id @default(cuid())
  address         String    @unique
  name            String
  slug            String    @unique @default(cuid())
  description     String?
  image           String?
  bannerImage     String?
  website         String?
  category        String    @default("m/ai-agents")
  avgRating       Float     @default(0)
  reviewCount     Int       @default(0)
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  athDropPct      Float?
  athPrice        Float?
  chain           String?
  coreFunctions   String?
  docs            String?
  github          String?
  humanScore      Int?
  marketCap       Float?
  marketUpdatedAt DateTime?
  offChainScore   Int?
  onChainScore    Int?
  price           Float?
  symbol          String?
  tier            String?
  trustGrade      String?
  trustScore      Int?
  trustUpdatedAt  DateTime?
  twitter         String?
  volume24h       Float?
  reviews         Review[]

  @@index([slug])
  @@index([address])
  @@index([category])
  @@index([chain])
  @@index([status])
  @@index([trustScore])
}

model Review {
  id              String   @id @default(cuid())
  rating          Int
  content         String
  upvotes         Int      @default(0)
  downvotes       Int      @default(0)
  status          String   @default("active")
  txHash          String?
  contentHash     String?
  onChainReviewId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reviewerId      String
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  reviewer        User     @relation(fields: [reviewerId], references: [id])
  votes           Vote[]

  @@index([reviewerId])
  @@index([projectId])
  @@index([createdAt])
  @@index([txHash])
}

model Vote {
  id        String   @id @default(cuid())
  direction String
  createdAt DateTime @default(now())
  voterId   String
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id])
  voter     User     @relation(fields: [voterId], references: [id])

  @@unique([voterId, reviewId])
  @@index([reviewId])
  @@index([voterId])
}

model ScarabBalance {
  id             String              @id @default(cuid())
  address        String              @unique
  balance        Int                 @default(0)
  totalEarned    Int                 @default(0)
  totalSpent     Int                 @default(0)
  totalPurchased Int                 @default(0)
  lastClaimAt    DateTime?
  streak         Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  transactions   ScarabTransaction[]

  @@index([address])
  @@index([balance])
}

model ScarabTransaction {
  id            String        @id @default(cuid())
  address       String
  amount        Int
  type          String
  description   String?
  referenceId   String?
  balanceAfter  Int
  createdAt     DateTime      @default(now())
  scarabBalance ScarabBalance @relation(fields: [address], references: [address])

  @@index([address])
  @@index([type])
  @@index([createdAt])
}

model ScarabPurchase {
  id           String    @id @default(cuid())
  address      String
  tier         String
  usdcAmount   Float
  scarabAmount Int
  txHash       String?
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  confirmedAt  DateTime?

  @@index([address])
  @@index([status])
}

model TrustReview {
  id           String   @id @default(cuid())
  address      String
  rating       Int
  comment      String   @default("")
  tags         String[] @default([])
  reviewer     String
  createdAt    DateTime @default(now())
  easReceiptId String?
  weight       Int      @default(1)

  @@index([address])
  @@index([reviewer])
  @@index([createdAt])
}

model EASReceipt {
  id              String   @id @default(cuid())
  recipient       String
  attester        String
  serviceProtocol String?
  txHash          String?
  receiptJson     String
  isOffchain      Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([recipient])
  @@index([attester])
  @@index([createdAt])
}

model Market {
  id          String           @id @default(cuid())
  title       String
  description String
  category    String
  status      String           @default("open")
  opensAt     DateTime
  closesAt    DateTime
  resolvedAt  DateTime?
  totalPool   Int              @default(0)
  winnerIds   String[]         @default([])
  createdAt   DateTime         @default(now())
  positions   MarketPosition[]

  @@index([status])
  @@index([category])
  @@index([closesAt])
}

model MarketPosition {
  id        String   @id @default(cuid())
  marketId  String
  projectId String
  voterId   String
  amount    Int
  payout    Int?
  createdAt DateTime @default(now())
  market    Market   @relation(fields: [marketId], references: [id])

  @@index([marketId])
  @@index([projectId])
  @@index([voterId])
}

model AgentCheckLog {
  id             String   @id @default(cuid())
  checkedAddress String
  checkerAddress String?
  paymentTxHash  String?
  score          Int
  verdict        String
  createdAt      DateTime @default(now())

  @@index([checkedAddress])
  @@index([checkerAddress])
}

model OutcomeReport {
  id            String   @id @default(cuid())
  sellerAddress String
  buyerAddress  String
  jobId         String?
  result        String
  paymentTxHash String?
  notes         String?
  createdAt     DateTime @default(now())

  @@index([sellerAddress])
  @@index([buyerAddress])
  @@index([result])
}

/// ACP Behavioral Trust Scores — indexed from Virtuals ACP on-chain job history
model AgentScore {
  id             String   @id @default(cuid())
  walletAddress  String   @unique @map("wallet_address")
  trustScore     Int      @map("trust_score")      // 0–100
  completionRate Float    @map("completion_rate")  // 0.0–1.0
  paymentRate    Float    @map("payment_rate")     // 0.0–1.0
  expireRate     Float    @map("expire_rate")      // 0.0–1.0 (ghosting)
  totalJobs      Int      @map("total_jobs")
  dataSource     String   @default("ACP_BEHAVIORAL") @map("data_source")
  lastUpdated    DateTime @updatedAt @map("last_updated")
  rawMetrics     Json     @map("raw_metrics")
  tokenAddress   String?  @map("token_address")    // Agent's token contract on Base (if any)
  tokenSymbol    String?  @map("token_symbol")

  @@map("agent_scores")
  @@index([walletAddress])
  @@index([trustScore])
  @@index([tokenAddress])
}
