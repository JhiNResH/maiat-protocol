generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String   @id @default(cuid())
  address         String   @unique
  displayName     String?
  type            String   @default("human") // "human" | "agent"
  avatarUrl       String?
  reputationScore Int      @default(0)
  totalReviews    Int      @default(0)
  totalUpvotes    Int      @default(0)
  erc8004AgentId  Int?     // ERC-8004 on-chain agent ID (null = not yet registered)
  privyWalletId   String?  // Privy server wallet ID for on-chain ops
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reviews         Review[]
  votes           Vote[]

  @@index([address])
  @@index([reputationScore])
}

model Project {
  id              String    @id @default(cuid())
  address         String    @unique
  name            String
  slug            String    @unique @default(cuid())
  description     String?
  image           String?
  bannerImage     String?
  website         String?
  category        String    @default("m/ai-agents")
  avgRating       Float     @default(0)
  reviewCount     Int       @default(0)
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  athDropPct      Float?
  athPrice        Float?
  chain           String?
  coreFunctions   String?
  docs            String?
  github          String?
  humanScore      Int?
  marketCap       Float?
  marketUpdatedAt DateTime?
  offChainScore   Int?
  onChainScore    Int?
  price           Float?
  symbol          String?
  tier            String?
  trustGrade      String?
  trustScore      Int?
  trustUpdatedAt  DateTime?
  twitter         String?
  volume24h       Float?
  reviews         Review[]

  @@index([slug])
  @@index([address])
  @@index([category])
  @@index([chain])
  @@index([status])
  @@index([trustScore])
}

model Review {
  id              String   @id @default(cuid())
  rating          Int
  content         String
  upvotes         Int      @default(0)
  downvotes       Int      @default(0)
  status          String   @default("active")
  txHash          String?
  contentHash     String?
  onChainReviewId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reviewerId      String
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  reviewer        User     @relation(fields: [reviewerId], references: [id])
  votes           Vote[]

  @@index([reviewerId])
  @@index([projectId])
  @@index([createdAt])
  @@index([txHash])
}

model Vote {
  id        String   @id @default(cuid())
  direction String
  createdAt DateTime @default(now())
  voterId   String
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id])
  voter     User     @relation(fields: [voterId], references: [id])

  @@unique([voterId, reviewId])
  @@index([reviewId])
  @@index([voterId])
}

model ScarabBalance {
  id             String              @id @default(cuid())
  address        String              @unique
  balance        Int                 @default(0)
  totalEarned    Int                 @default(0)
  totalSpent     Int                 @default(0)
  totalPurchased Int                 @default(0)
  lastClaimAt    DateTime?
  streak         Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  transactions   ScarabTransaction[]

  @@index([address])
  @@index([balance])
}

model ScarabTransaction {
  id            String        @id @default(cuid())
  address       String
  amount        Int
  type          String
  description   String?
  referenceId   String?
  balanceAfter  Int
  createdAt     DateTime      @default(now())
  scarabBalance ScarabBalance @relation(fields: [address], references: [address])

  @@index([address])
  @@index([type])
  @@index([createdAt])
}

model ScarabPurchase {
  id           String    @id @default(cuid())
  address      String
  tier         String
  usdcAmount   Float
  scarabAmount Int
  txHash       String?
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  confirmedAt  DateTime?

  @@index([address])
  @@index([status])
}

model TrustReview {
  id             String   @id @default(cuid())
  address        String
  rating         Int
  comment        String   @default("")
  tags           String[] @default([])
  reviewer       String
  createdAt      DateTime @default(now())
  easReceiptId   String?
  weight         Int      @default(1)
  source         String?  @default("human")
  // AI quality scoring
  qualityScore   Float?             // 0-10 from Gemini
  relevance      Float?             // 0-10
  evidence       Float?             // 0-10
  helpfulness    Float?             // 0-10
  reviewerType   String   @default("human")  // "human" | "agent"
  hasEas         Boolean  @default(false)     // reviewer has EAS attestation
  interactionTier String  @default("none")   // "acp" | "onchain" | "none"
  upvotes        Int      @default(0)         // "helpful" count
  downvotes      Int      @default(0)         // "not helpful" count

  @@index([address])
  @@index([reviewer])
  @@index([createdAt])
  @@index([qualityScore])
}

model ReviewVote {
  id         String   @id @default(cuid())
  reviewId   String
  voter      String                           // wallet address of voter
  vote       String                           // "up" | "down"
  weight     Int      @default(1)             // 1=unverified, 2=onchain, 3=acp
  createdAt  DateTime @default(now())

  @@unique([reviewId, voter])                 // one vote per review per person
  @@map("review_votes")
  @@index([reviewId])
  @@index([voter])
}

model EASReceipt {
  id              String   @id @default(cuid())
  recipient       String
  attester        String
  serviceProtocol String?
  txHash          String?
  receiptJson     String
  isOffchain      Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([recipient])
  @@index([attester])
  @@index([createdAt])
}

model Market {
  id          String           @id @default(cuid())
  title       String
  description String
  category    String
  status      String           @default("open")
  opensAt     DateTime
  closesAt    DateTime
  resolvedAt  DateTime?
  totalPool   Int              @default(0)
  winnerIds   String[]         @default([])
  createdAt   DateTime         @default(now())
  positions   MarketPosition[]

  @@index([status])
  @@index([category])
  @@index([closesAt])
}

model MarketPosition {
  id           String   @id @default(cuid())
  marketId     String
  projectId    String
  voterId      String
  amount       Int
  payout       Int?
  agentAddress String?  @map("agent_address")  // For agent opinion markets (Phase 2)
  createdAt    DateTime @default(now())
  market       Market   @relation(fields: [marketId], references: [id])

  @@index([marketId])
  @@index([projectId])
  @@index([voterId])
}

model AgentCheckLog {
  id             String   @id @default(cuid())
  checkedAddress String
  checkerAddress String?
  paymentTxHash  String?
  score          Int
  verdict        String
  createdAt      DateTime @default(now())

  @@index([checkedAddress])
  @@index([checkerAddress])
}

model OutcomeReport {
  id            String   @id @default(cuid())
  sellerAddress String
  buyerAddress  String
  jobId         String?
  result        String
  paymentTxHash String?
  notes         String?
  createdAt     DateTime @default(now())

  @@index([sellerAddress])
  @@index([buyerAddress])
  @@index([result])
}

/// ACP Behavioral Trust Scores — indexed from Virtuals ACP on-chain job history
model AgentScore {
  id             String   @id @default(cuid())
  walletAddress  String   @unique @map("wallet_address")
  trustScore     Int      @map("trust_score")      // 0–100
  completionRate Float    @map("completion_rate")  // 0.0–1.0
  paymentRate    Float    @map("payment_rate")     // 0.0–1.0
  expireRate     Float    @map("expire_rate")      // 0.0–1.0 (ghosting)
  totalJobs      Int      @map("total_jobs")
  dataSource     String   @default("ACP_BEHAVIORAL") @map("data_source")
  lastUpdated    DateTime @updatedAt @map("last_updated")
  rawMetrics     Json     @map("raw_metrics")
  tokenAddress   String?  @map("token_address")    // Agent's token contract on Base (if any)
  tokenSymbol    String?  @map("token_symbol")

  @@map("agent_scores")
  @@index([walletAddress])
  @@index([trustScore])
  @@index([tokenAddress])
}

/// Query log for all ACP offering calls — training data for Maiat's trust model
model QueryLog {
  id          String   @id @default(cuid())
  type        String   // "agent_trust" | "token_check" | "trust_swap"
  target      String   // checked address (agent wallet or token address)
  buyer       String?  // buyer wallet (who called the offering)
  jobId       String?  // ACP job ID
  trustScore  Int?     // 0-100
  verdict     String?  // proceed | caution | avoid
  amountIn    String?  // for trust_swap: input amount
  amountOut   String?  // for trust_swap: quoted output
  clientId    String?  // SDK client identifier (X-Maiat-Client header)
  metadata    Json?    // full response snapshot for ML training
  prevHash    String?  // SHA-256 of the previous QueryLog.recordHash for same target
  recordHash  String?  // SHA-256(id + type + target + trustScore + verdict + createdAt + prevHash)
  outcome     String?  // Actual result reported back via POST /api/v1/outcome
                       // "success" | "failure" | "partial" | "expired" — null until reported
  createdAt   DateTime @default(now())

  @@map("query_logs")
  @@index([type])
  @@index([target])
  @@index([createdAt])
  @@index([verdict])
  @@index([target, createdAt]) // for evidence chain lookups
  @@index([recordHash])        // for chain integrity lookups
}

model Outcome {
  id            String   @id @default(cuid())
  target        String   // agent/token address that was checked
  action        String   // swap | delegate | hire | skip | block | other
  result        String   // success | failure | scam | partial | pending
  txHash        String?  // on-chain proof
  maiatVerdict  String?  // what Maiat said at check time
  maiatScore    Int?     // trust score at check time
  clientId      String?  // which SDK client reported this
  notes         String?  // free-form context
  createdAt     DateTime @default(now())

  @@map("outcomes")
  @@index([target])
  @@index([result])
  @@index([clientId])
  @@index([createdAt])
}

model CallerWallet {
  id            String   @id @default(cuid())
  clientId      String   @unique        // X-Maiat-Client header value
  walletAddress String                  // Privy server wallet address
  walletId      String?                 // Privy wallet ID for signing
  provider      String   @default("privy")
  totalOutcomes Int      @default(0)    // total outcomes reported
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("caller_wallets")
  @@index([walletAddress])
}

/// Threat reports submitted by Guard when it intercepts malicious activity
model ThreatReport {
  id               String   @id @default(cuid())
  maliciousAddress String
  threatType       String   // "address_poisoning" | "low_trust" | "vanity_match" | "dust_liveness"
  evidence         Json
  guardVersion     String?
  chainId          Int?
  reporterIp       String?  // SHA-256 hashed, never raw
  timestamp        DateTime
  createdAt        DateTime @default(now())

  @@map("threat_reports")
  @@index([maliciousAddress])
  @@index([threatType])
  @@index([createdAt])
}

/// Wadjet alerts now live in wadjet service DB (Railway)
/// Protocol queries them via wadjet-client.ts → /sentinel/alerts

/// KYA (Know Your Agent) — Twitter endorsement system
model KyaCode {
  id                String           @id @default(cuid())
  code              String           @unique // MAIAT-XXXX (8 char)
  agentAddress      String // wallet address of the agent
  agentName         String? // display name
  twitterHandle     String? // @AgentName
  totalEndorsements Int              @default(0)
  trustBoost        Int              @default(0) // accumulated trust score boost
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  endorsements      KyaEndorsement[]

  @@map("kya_codes")
  @@index([agentAddress])
  @@index([code])
}

/// Used EIP-712 auth signatures — replay protection for POST /api/v1/auth/agent
/// Rows with expiresAt < NOW() can be pruned by a cron job.
model UsedAuthSignature {
  id        String   @id @default(cuid())
  sigHash   String   @unique // keccak256 of the raw signature hex
  address   String   // lowercase wallet address
  expiresAt DateTime // timestamp + 5 min
  createdAt DateTime @default(now())

  @@map("used_auth_signatures")
  @@index([address])
  @@index([expiresAt])
}

model KyaEndorsement {
  id              String   @id @default(cuid())
  kyaCodeId       String
  kyaCode         KyaCode  @relation(fields: [kyaCodeId], references: [id])
  endorserAddress String // wallet of the person endorsing
  tweetUrl        String // the tweet URL as proof
  referrer        String? // ENS name of referrer (from ?ref= param)
  status          String   @default("pending") // pending | verified | rejected
  scarabAwarded   Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([kyaCodeId, endorserAddress]) // one endorsement per user per agent
  @@map("kya_endorsements")
  @@index([endorserAddress])
  @@index([status])
}

/// Indexer state for incremental/segmented pagination (avoids Vercel 5min timeout)
model IndexerState {
  id              String    @id @default("acp-indexer")
  lastPage        Int       @default(0) @map("last_page")
  totalPages      Int       @default(0) @map("total_pages")
  lastFullCycleAt DateTime? @map("last_full_cycle_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("indexer_state")
}

/// MAIAT V2 DOJO MVP — Agent skill marketplace
/// Created agents (ERC-8004 identities with TBA wallets)
model Agent {
  id                String               @id @default(cuid())
  erc8004Id         Int?                 @unique @map("erc8004_id") // on-chain agent identity
  erc6551Tba        String?              @map("erc6551_tba")         // ERC-6551 token-bound account
  ownerAddress      String               @map("owner_address")       // creator's wallet
  name              String
  description       String?
  avatarUrl         String?              @map("avatar_url")
  template          String               @default("assistant")      // "assistant" | "analyst" | "trader" | etc
  xp                Int                  @default(0)
  level             Int                  @default(1)                // Kozo=1, Senpai=2, Tatsujin=3, Sensei=4
  rank              String               @default("kozo")           // "kozo" | "senpai" | "tatsujin" | "sensei"
  
  // Reputation
  trustScore        Int                  @default(0)                // 0-100
  completionRate    Float                @default(0.0)              // 0.0-1.0
  totalJobs         Int                  @default(0)
  totalEarned       Float                @default(0.0)              // in USDC
  
  // Status
  isPublished       Boolean              @default(false)            // shown in Dojo?
  isPaused          Boolean              @default(false)
  
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  
  // Relations
  equippedSkills    SkillEquipment[]
  jobHistory        Job[]
  
  @@map("agents")
  @@index([ownerAddress])
  @@index([erc8004Id])
  @@index([trustScore])
  @@index([isPublished])
}

/// Skills that creators can sell via Dojo
/// Each skill is an ERC-1155 NFT (one skill type = many copies)
model Skill {
  id                String               @id @default(cuid())
  erc1155Id         Int?                 @unique @map("erc1155_id")  // on-chain token ID
  
  // Metadata
  name              String
  description       String
  category          String                                          // "analysis" | "trading" | "monitoring" | etc
  tags              String[]             @default([])
  
  // Creator
  creatorAddress    String               @map("creator_address")
  creatorName       String?              @map("creator_name")
  creatorAvatar     String?              @map("creator_avatar")
  
  // Content
  skillMarkdownUrl  String               @map("skill_markdown_url")  // IPFS or S3 URL to SKILL.md
  skillMarkdown     String               @default("")               // stored inline for quick access
  
  // Pricing
  priceUsdc         Float                @map("price_usdc")         // in USDC
  isPro             Boolean              @default(false)            // true = paid only
  
  // Stats
  totalPurchases    Int                  @default(0)                // cumulative sales
  totalInstalls     Int                  @default(0)                // agents equipped with it
  avgRating         Float                @default(0.0)
  reviewCount       Int                  @default(0)
  
  // Royalties
  royaltyPercent    Int                  @default(15)               // % of skill sales to creator
  royaltySplitter   String?              @map("royalty_splitter")   // on-chain splitter contract
  
  // Status
  isPublished       Boolean              @default(false)
  isFeatured        Boolean              @default(false)
  
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  
  // Relations
  purchases         SkillPurchase[]
  equipped          SkillEquipment[]
  reviews           SkillReview[]
  
  @@map("skills")
  @@index([creatorAddress])
  @@index([category])
  @@index([isPublished])
  @@index([avgRating])
}

/// Purchase record for skill NFTs
/// Buyer → USDC payment → mint ERC-1155 → auto-equip to their TBA
model SkillPurchase {
  id                String               @id @default(cuid())
  
  // Parties
  buyerAddress      String               @map("buyer_address")
  skillId           String               @map("skill_id")
  skill             Skill                @relation(fields: [skillId], references: [id])
  
  // Payment
  txHash            String?              @map("tx_hash")             // on-chain purchase tx
  amountUsdc        Float                @map("amount_usdc")
  status            String               @default("pending")        // "pending" | "completed" | "failed" | "refunded"
  
  // NFT minting
  nftTokenId        Int?                 @map("nft_token_id")        // ERC-1155 token ID
  autoEquipped      Boolean              @default(false)
  
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  
  @@map("skill_purchases")
  @@index([buyerAddress])
  @@index([skillId])
  @@index([status])
  @@index([txHash])
}

/// Skill equipped to an agent's ERC-6551 TBA
/// An agent can equip multiple skills to build their "build"
model SkillEquipment {
  id                String               @id @default(cuid())
  
  // Agent + Skill
  agentId           String               @map("agent_id")
  agent             Agent                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skillId           String               @map("skill_id")
  skill             Skill                @relation(fields: [skillId], references: [id], onDelete: Cascade)
  
  // TBA wallet receipt
  nftTokenId        Int?                 @map("nft_token_id")        // ERC-1155 token ID held in TBA
  
  // Status
  isActive          Boolean              @default(true)
  
  equippedAt        DateTime             @default(now())
  unequippedAt      DateTime?            @map("unequipped_at")
  
  @@unique([agentId, skillId])
  @@map("skill_equipment")
  @@index([agentId])
  @@index([skillId])
  @@index([isActive])
}

/// Jobs = agent-as-a-service requests
/// Buyer picks a skill and an agent, agent executes, gets paid
model Job {
  id                String               @id @default(cuid())
  
  // Parties
  buyerAddress      String               @map("buyer_address")
  agentId           String               @map("agent_id")
  agent             Agent                @relation(fields: [agentId], references: [id])
  skillId           String               @map("skill_id")
  
  // Request + Execution
  inputPrompt       String               @map("input_prompt")       // what buyer asked
  outputResult      String?              @map("output_result")      // agent's response
  executionTime     Int?                 @map("execution_time")     // ms to complete
  
  // Evaluation
  verdict           String?              // "pass" | "fail" | "partial" (Micro Evaluator)
  evaluatorNote     String?              @map("evaluator_note")
  
  // Payment
  amountUsdc        Float?               @map("amount_usdc")
  txHash            String?              @map("tx_hash")
  status            String               @default("open")          // "open" | "funded" | "active" | "completed" | "failed"
  
  // Reputation
  buyerRating       Int?                 @map("buyer_rating")       // 1-5
  buyerReview       String?              @map("buyer_review")
  
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  
  @@map("jobs")
  @@index([buyerAddress])
  @@index([agentId])
  @@index([status])
  @@index([verdict])
}

/// Reviews of skills (like product reviews)
model SkillReview {
  id                String               @id @default(cuid())
  skillId           String               @map("skill_id")
  skill             Skill                @relation(fields: [skillId], references: [id], onDelete: Cascade)
  
  reviewerAddress   String               @map("reviewer_address")
  rating            Int                  // 1-5
  comment           String               @default("")
  
  // EAS attestation
  easAttestationId  String?              @map("eas_attestation_id")
  
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  
  @@unique([skillId, reviewerAddress])
  @@map("skill_reviews")
  @@index([skillId])
  @@index([reviewerAddress])
}

/// Attestations created after job completion
/// One per job → written to EAS on Base → updates TrustScoreOracle
model JobAttestation {
  id                String               @id @default(cuid())
  jobId             String               @map("job_id")
  agentId           String               @map("agent_id")
  
  verdict           String               // "pass" | "fail" | "partial"
  evaluatorAddress  String               @map("evaluator_address")
  
  // EAS
  easReceiptId      String?              @map("eas_receipt_id")      // Base EAS
  easSchemaId       String?              @map("eas_schema_id")
  
  createdAt         DateTime             @default(now())
  
  @@map("job_attestations")
  @@index([jobId])
  @@index([agentId])
}

/// Leaderboard cache (updated hourly or on-demand)
model LeaderboardEntry {
  id                String               @id @default(cuid())
  agentId           String               @unique @map("agent_id")
  
  rank              Int
  trustScore        Int                  @map("trust_score")
  completionRate    Float                @map("completion_rate")
  totalJobs         Int                  @default(0)
  totalEarned       Float                @map("total_earned")
  
  lastUpdatedAt     DateTime             @updatedAt @map("last_updated_at")
  
  @@map("leaderboard_entries")
  @@index([rank])
}
