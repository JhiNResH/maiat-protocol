{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/demo",
      "destination": "/demo/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/resolve-markets",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/v1/cron/index-agents",
      "schedule": "0 */8 * * *"
    },
    {
      "path": "/api/v1/cron/auto-attest",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/v1/cron/oracle-sync",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/v1/cron/register-agents",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/v1/cron/write-intuition-triples",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/v1/cron/refresh-scores",
      "schedule": "0 6 * * *"
    }
  ]
}
