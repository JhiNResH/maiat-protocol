{
  "name": "@jhinresh/virtuals-plugin",
  "version": "0.2.2",
  "description": "Maiat Trust Score plugin for Virtuals GAME SDK \u2014 trust-gate agent transactions on Virtuals Protocol",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "peerDependencies": {
    "@virtuals-protocol/game": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@virtuals-protocol/game": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@virtuals-protocol/game": "^0.1.14"
  },
  "keywords": [
    "maiat",
    "virtuals",
    "game-sdk",
    "trust-score",
    "ai-agent",
    "web3",
    "virtual-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JhiNResH/maiat-protocol"
  }
}